# AI api keys
GROQ_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
TAVILY_API_KEY=
 
# Turso database configuration
DATABASE_URL=libsql://your-database-name.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token-here

# Document webhook (optional - for sending documents to users)
# DOCUMENT_WEBHOOK_URL=https://your-backend.com/api/document-webhook
# DOCUMENT_WEBHOOK_SECRET=your-webhook-secret-here

# S3 Document Search (optional - for searching documents in S3)
# S3_BUCKET_NAME=your-bucket-name
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your-access-key-id
# S3_SECRET_ACCESS_KEY=your-secret-access-key
# S3_PRESIGNED_URL_EXPIRY=3600

# Logging (optional)
# LOG_LEVEL=INFO
# LOG_FILE=logs/agno_agent_api.log
# LOG_FORMAT=text